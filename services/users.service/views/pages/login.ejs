<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Login</title>

<!-- Bootstrap 5 -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body {
    background: linear-gradient(135deg, #0d9488, #0d9488);
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
}

.login-card {
    width: 100%;
    max-width: 400px;
    padding: 2rem;
    border-radius: 12px;
    background: white;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
}

.login-title {
    font-weight: 700;
    text-align: center;
    margin-bottom: 1.5rem;
}

.btn-primary {
    background-color: #667eea;
    border: none;
}

.btn-primary:hover {
    background-color: #5a67d8;
}

.form-control:focus {
    box-shadow: none;
    border-color: #667eea;
}

.error-message {
    color: red;
    font-size: 0.9rem;
    text-align: center;
    margin-bottom: 1rem;
}
</style>
</head>

<body>

<div class="login-card">

<h3 class="login-title">Login to ANIMETA </h3>

<% if (typeof error !== 'undefined') { %>
    <div class="error-message"><%= error %></div>
<% } %>

<form method="POST" action="">

    <div class="mb-3">
    <label class="form-label">Email</label>
    <input 
        type="email" 
        name="email" 
        class="form-control" 
        placeholder="Enter your email"
        required
    >
    </div>

    <div class="mb-3">
    <label class="form-label">Password</label>
    <input 
        type="password" 
        name="password" 
        class="form-control" 
        placeholder="Enter your password"
        required
    >
    </div>

    <div class="d-grid">
    <button type="submit" class="btn btn-primary">
        Sign in
    </button>
    </div>

</form>

</div>

</body>
</html>