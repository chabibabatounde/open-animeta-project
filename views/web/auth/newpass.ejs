<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Reset Password</title>

<!-- ✅ Bootstrap -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body {
    background: linear-gradient(135deg, #0d9488, #0d9488);
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
}

.login-card {
    width: 100%;
    max-width: 400px;
    padding: 2rem;
    border-radius: 12px;
    background: white;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
}

.login-title {
    font-weight: 700;
    text-align: center;
    margin-bottom: 1.5rem;
}

.btn-primary {
    background-color: #667eea;
    border: none;
}

.btn-primary:hover {
    background-color: #5a67d8;
}

.form-control:focus {
    box-shadow: none;
    border-color: #667eea;
}

.error-message {
    color: red;
    font-size: 0.9rem;
    text-align: center;
    margin-bottom: 1rem;
}
</style>
</head>

<body>

<div class="login-card">

  <h3 class="login-title">Reset Password</h3>

  <% if (error) { %>
    <div class="error-message"><%= error %></div>
  <% } %>

  <form method="POST">

    <input type="hidden" name="token" value="<%= token %>">

    <div class="mb-3">
      <input 
        type="password" 
        name="password" 
        class="form-control" 
        placeholder="New password" 
        required
      >
    </div>

    <div class="mb-3">
      <input 
        type="password" 
        name="confirmPassword" 
        class="form-control" 
        placeholder="Confirm password" 
        required
      >
    </div>

    <button class="btn btn-primary w-100">
      Reset password
    </button>

  </form>

  <div class="text-center mt-3">
    <a href="/auth/modeling">Back to login</a>
  </div>

</div>

</body>
</html>