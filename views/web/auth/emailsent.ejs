<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Account Created</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body {
    background: linear-gradient(135deg, #0d9488, #0d9488);
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
}

.success-card {
    width: 100%;
    max-width: 420px;
    padding: 2rem;
    border-radius: 12px;
    background: white;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    text-align: center;
}

.success-icon {
    font-size: 50px;
    color: #10b981;
    margin-bottom: 1rem;
}

.success-title {
    font-weight: 700;
    margin-bottom: 1rem;
}

.success-text {
    color: #555;
    margin-bottom: 1.5rem;
}

.btn-primary {
    background-color: #667eea;
    border: none;
}

.btn-primary:hover {
    background-color: #5a67d8;
}
</style>
</head>

<body>

<div class="success-card">

    <div class="success-icon">✅</div>

    <h3 class="success-title">Account Created!</h3>

    <p class="success-text">
        Your account has been successfully created.<br>
        An activation email has been sent to:
    </p>

    <p><strong><%= email %></strong></p>

    <p class="success-text">
        Please check your inbox and click the activation link to activate your account.
    </p>

    <a href="/auth/modeling" class="btn btn-primary w-100">
        Back to Login
    </a>

</div>

</body>
</html>